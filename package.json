{
	"name": "notely-cli",
	"version": "1.0.0",
	"description": "Your minimal note-taking tool for the terminal.",
	"author": "gazi2050",
	"homepage": "https://notely-cli.vercel.app",
	"repository": {
		"url": "https://github.com/Gazi2050/notely-cli"
	},
	"license": "MIT",
	"keywords": [
		"package",
		"note",
		"cli",
		"terminal"
	],
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"cli": "node --no-warnings --loader ts-node/esm source/cli.tsx",
		"format": "prettier --write .",
		"test": "prettier --check . && xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@inkjs/ui": "2.0.0",
		"cli-table3": "^0.6.5",
		"dayjs": "^1.11.19",
		"ink": "5.2.1",
		"ink-big-text": "^2.0.0",
		"lowdb": "^7.0.1",
		"meow": "^11.0.0",
		"react": "^18.2.0",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^3.0.1",
		"@types/node": "^25.3.5",
		"@types/react": "^18.0.32",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^5.2.0",
		"chalk": "^5.2.0",
		"eslint-config-xo-react": "^0.27.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-react-hooks": "^4.6.0",
		"ink-testing-library": "^3.0.0",
		"prettier": "^2.8.7",
		"ts-node": "^10.9.1",
		"typescript": "^5.0.3",
		"xo": "^0.53.1"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off",
			"unicorn/expiring-todo-comments": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
